# =============================================================================
# ArcadeOrchestrator — .gitignore
# Stack: C# 12 · .NET 8 · WPF · Windows 10/11
# =============================================================================

# ─── .NET / MSBuild ──────────────────────────────────────────────────────────
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
project.lock.json
artifacts/
packages/
!packages/repositories.config
publish/
**/publish/

# ─── Visual Studio ───────────────────────────────────────────────────────────
.vs/
*.VC.db
*.VC.opendb
*.pidb
*.ncb
*.opendb
*.sdf
*.cachefile
*.psess
*.vsp
*.vspx
TestResult.xml
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# ─── Rider / JetBrains ───────────────────────────────────────────────────────
.idea/
*.sln.iml

# ─── VS Code ─────────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# ─── ArcadeOrchestrator — Logs de runtime ────────────────────────────────────
logs/
!logs/.gitkeep

# ─── ArcadeOrchestrator — Config local ───────────────────────────────────────
config/config.local.yaml
config/catalog.local.yaml
!config/config.yaml
!config/catalog.yaml

# ─── ArcadeOrchestrator — Dados de sessão ────────────────────────────────────
*.jsonl

# ─── Windows ─────────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ─── Cobertura de testes ─────────────────────────────────────────────────────
coverage/
TestResults/
*.trx
*.coveragexml
lcov.info

# ─── Certificados e segredos ─────────────────────────────────────────────────
*.pfx
*.p12
*.key
secrets.json
